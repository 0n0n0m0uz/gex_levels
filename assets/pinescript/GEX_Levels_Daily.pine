//@version=5
indicator("GEX Levels Daily", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=20)

// ═══════════════════════════════════════════════════════════════
//  PASTE UPDATED DATA HERE EACH DAY
// ═══════════════════════════════════════════════════════════════
var string SYM        = "QQQ"
var string TIMESTAMP  = "2026-07-21"
var float UNDERLYING  = 708.97

// -- 30D levels ----------------------------------------------
var string REGIME_30     = "negative_gamma"
var float GAMMA_FLIP_30  = 710.94
var float VOL_TRIGGER_30 = 711.00
var float HVL_30         = 705.76
var float CALL_WALL_30   = 729.00
var float CW_LOW_30      = 713.00
var float CW_HIGH_30     = 729.00
var float PUT_WALL_30    = 690.00
var float PW_LOW_30      = 700.00
var float PW_HIGH_30     = 690.00
var float KEY_CALL_2_30  = 720.00
var float KEY_CALL_3_30  = 730.00
var float KEY_PUT_2_30   = 700.00
var float KEY_PUT_3_30   = 695.00
var string NET_GEX_30    = "-254.6M"
var float  NET_DEX_30    = -18886862.0
var string DEX_REGIME_30 = "dealer_short"
var float  CPR_RAW_30    = 0.5785
var float  CPR_NOTL_30   = 0.6261
var float GEX_NODE1_P_30 = 700.00
var float GEX_NODE1_V_30 = -250541384.0
var float GEX_NODE2_P_30 = 690.00
var float GEX_NODE2_V_30 = -172521778.0
var float GEX_NODE3_P_30 = 695.00
var float GEX_NODE3_V_30 = -142157325.0
var float GEX_NODE4_P_30 = 720.00
var float GEX_NODE4_V_30 = 118945855.0
var float GEX_NODE5_P_30 = 730.00
var float GEX_NODE5_V_30 = 110333517.0

// -- 90D levels ----------------------------------------------
var string REGIME_90     = "negative_gamma"
var float GAMMA_FLIP_90  = 713.41
var float VOL_TRIGGER_90 = 714.00
var float HVL_90         = 705.07
var float CALL_WALL_90   = 735.00
var float CW_LOW_90      = 715.00
var float CW_HIGH_90     = 735.00
var float PUT_WALL_90    = 681.00
var float PW_LOW_90      = 700.00
var float PW_HIGH_90     = 681.00
var float KEY_CALL_2_90  = 730.00
var float KEY_CALL_3_90  = 733.00
var float KEY_PUT_2_90   = 700.00
var float KEY_PUT_3_90   = 690.00
var string NET_GEX_90    = "-923.2M"
var float  NET_DEX_90    = -51018127.2
var string DEX_REGIME_90 = "dealer_short"
var float  CPR_RAW_90    = 0.6262
var float  CPR_NOTL_90   = 0.6863
var float GEX_NODE1_P_90 = 700.00
var float GEX_NODE1_V_90 = -511210965.0
var float GEX_NODE2_P_90 = 690.00
var float GEX_NODE2_V_90 = -419941242.0
var float GEX_NODE3_P_90 = 695.00
var float GEX_NODE3_V_90 = -333339619.0
var float GEX_NODE4_P_90 = 730.00
var float GEX_NODE4_V_90 = 289827199.0
var float GEX_NODE5_P_90 = 680.00
var float GEX_NODE5_V_90 = -261350413.0

// ═══════════════════════════════════════════════════════════════

// ── Settings ─────────────────────────────────────────────────────
dte_mode      = input.string("Both", "DTE Window", options=["30 Day", "90 Day", "Both"])
show_zones    = input.bool(true,  "Show Call/Put Wall Zones")
show_key      = input.bool(true,  "Show Key Call/Put Levels")
show_nodes    = input.bool(true,  "Show Top GEX Profile Nodes")
show_underlyi = input.bool(true,  "Show Underlying Reference Line")
show_table    = input.bool(true,  "Show Info Table")
lw            = input.int(2, "Line Width", minval=1, maxval=4)

show_30 = dte_mode == "30 Day" or dte_mode == "Both"
show_90 = dte_mode == "90 Day" or dte_mode == "Both"

sty_30 = line.style_solid
sty_90 = dte_mode == "Both" ? line.style_dashed : line.style_solid

// ── Colors ────────────────────────────────────────────────────────
C_CALL   = color.new(color.green,   10)
C_PUT    = color.new(color.red,     10)
C_FLIP   = color.new(color.orange,  10)
C_HVL    = color.new(color.aqua,    10)
C_KEY_C  = color.new(color.lime,    30)
C_KEY_P  = color.new(color.maroon,  10)
C_UND    = color.new(color.white,   30)
C_NODE_C = color.new(color.teal,    20)
C_NODE_P = color.new(color.fuchsia, 20)

// ── Draw functions ────────────────────────────────────────────────
f_line(price, col, sty) =>
    line.new(bar_index - 100, price, bar_index, price, color=col, width=lw, style=sty, extend=extend.right)

f_label(price, txt, col, x_off) =>
    label.new(bar_index + x_off, price, txt, color=color.new(col, 88), textcolor=col, style=label.style_label_lower_left, size=size.small)

// Each label has a unique x offset so they never overlap regardless of price
f_draw_set(gf, vt, hvl, cw, cw_low, cw_high, pw, pw_low, pw_high, kc2, kc3, kp2, kp3, n1p, n1v, n2p, n2v, n3p, n3v, n4p, n4v, n5p, n5v, sty, lbl_suffix) =>
    f_line(cw, C_CALL, sty)
    f_label(cw,  "Call Wall " + lbl_suffix + "  " + str.tostring(cw),  C_CALL, 2)

    f_line(pw, C_PUT, sty)
    f_label(pw,  "Put Wall " + lbl_suffix + "  "  + str.tostring(pw),  C_PUT,  12)

    f_line(gf, C_FLIP, sty)
    f_label(gf,  "Gamma Flip " + lbl_suffix + "  " + str.tostring(gf), C_FLIP, 22)

    if vt != gf
        f_line(vt, color.new(color.yellow, 10), sty)
        f_label(vt, "Vol Trigger " + lbl_suffix + "  " + str.tostring(vt), color.new(color.yellow, 10), 32)

    f_line(hvl, C_HVL, sty == line.style_solid ? line.style_dashed : line.style_dotted)
    f_label(hvl, "HVL " + lbl_suffix + "  " + str.tostring(hvl), C_HVL, 42)

    if show_key
        f_line(kc2, C_KEY_C, sty == line.style_solid ? line.style_dashed : line.style_dotted)
        f_label(kc2, "Key Call 2 " + lbl_suffix + "  " + str.tostring(kc2), C_KEY_C, 52)
        f_line(kc3, C_KEY_C, line.style_dotted)
        f_label(kc3, "Key Call 3 " + lbl_suffix + "  " + str.tostring(kc3), C_KEY_C, 62)
        f_line(kp2, C_KEY_P, sty == line.style_solid ? line.style_dashed : line.style_dotted)
        f_label(kp2, "Key Put 2 " + lbl_suffix + "  "  + str.tostring(kp2), C_KEY_P, 72)
        f_line(kp3, C_KEY_P, line.style_dotted)
        f_label(kp3, "Key Put 3 " + lbl_suffix + "  "  + str.tostring(kp3), C_KEY_P, 82)

    if show_zones
        if cw_high != cw_low
            box.new(bar_index - 100, cw_high, bar_index, cw_low, border_color=color.new(C_CALL, 50), bgcolor=color.new(C_CALL, 88), extend=extend.right)
        if pw_high != pw_low
            box.new(bar_index - 100, pw_high, bar_index, pw_low, border_color=color.new(C_PUT, 50), bgcolor=color.new(C_PUT, 88), extend=extend.right)

    if show_nodes
        if not na(n1p)
            f_line(n1p, n1v >= 0 ? C_NODE_C : C_NODE_P, sty)
            f_label(n1p, "Node 1 " + lbl_suffix + "  " + str.tostring(n1p), n1v >= 0 ? C_NODE_C : C_NODE_P, 92)
        if not na(n2p)
            f_line(n2p, n2v >= 0 ? C_NODE_C : C_NODE_P, sty)
            f_label(n2p, "Node 2 " + lbl_suffix + "  " + str.tostring(n2p), n2v >= 0 ? C_NODE_C : C_NODE_P, 102)
        if not na(n3p)
            f_line(n3p, n3v >= 0 ? C_NODE_C : C_NODE_P, sty)
            f_label(n3p, "Node 3 " + lbl_suffix + "  " + str.tostring(n3p), n3v >= 0 ? C_NODE_C : C_NODE_P, 112)
        if not na(n4p)
            f_line(n4p, n4v >= 0 ? C_NODE_C : C_NODE_P, sty)
            f_label(n4p, "Node 4 " + lbl_suffix + "  " + str.tostring(n4p), n4v >= 0 ? C_NODE_C : C_NODE_P, 122)
        if not na(n5p)
            f_line(n5p, n5v >= 0 ? C_NODE_C : C_NODE_P, sty)
            f_label(n5p, "Node 5 " + lbl_suffix + "  " + str.tostring(n5p), n5v >= 0 ? C_NODE_C : C_NODE_P, 132)

// ── Lines and labels (last bar only) ─────────────────────────────
if barstate.islast
    if show_underlyi
        f_line(UNDERLYING, C_UND, line.style_dotted)
        f_label(UNDERLYING, "Underlying  " + str.tostring(UNDERLYING), C_UND, 2)

    if show_30
        f_draw_set(GAMMA_FLIP_30, VOL_TRIGGER_30, HVL_30, CALL_WALL_30, CW_LOW_30, CW_HIGH_30, PUT_WALL_30, PW_LOW_30, PW_HIGH_30, KEY_CALL_2_30, KEY_CALL_3_30, KEY_PUT_2_30, KEY_PUT_3_30, GEX_NODE1_P_30, GEX_NODE1_V_30, GEX_NODE2_P_30, GEX_NODE2_V_30, GEX_NODE3_P_30, GEX_NODE3_V_30, GEX_NODE4_P_30, GEX_NODE4_V_30, GEX_NODE5_P_30, GEX_NODE5_V_30, sty_30, "30d")

    if show_90
        f_draw_set(GAMMA_FLIP_90, VOL_TRIGGER_90, HVL_90, CALL_WALL_90, CW_LOW_90, CW_HIGH_90, PUT_WALL_90, PW_LOW_90, PW_HIGH_90, KEY_CALL_2_90, KEY_CALL_3_90, KEY_PUT_2_90, KEY_PUT_3_90, GEX_NODE1_P_90, GEX_NODE1_V_90, GEX_NODE2_P_90, GEX_NODE2_V_90, GEX_NODE3_P_90, GEX_NODE3_V_90, GEX_NODE4_P_90, GEX_NODE4_V_90, GEX_NODE5_P_90, GEX_NODE5_V_90, sty_90, "90d")

// ── Info Table ────────────────────────────────────────────────────
var table tbl = table.new(position.top_right, 3, 12, border_width=1, border_color=color.new(color.gray, 60), bgcolor=color.new(color.black, 75))

if barstate.islast and show_table
    table.cell(tbl, 0, 0,  "GEX · " + SYM,   text_color=color.white,  text_size=size.normal, bgcolor=color.new(color.navy, 50))
    table.cell(tbl, 1, 0,  "30 Day",           text_color=color.yellow, text_size=size.small,  bgcolor=color.new(color.navy, 50))
    table.cell(tbl, 2, 0,  "90 Day",           text_color=color.silver, text_size=size.small,  bgcolor=color.new(color.navy, 50))

    table.cell(tbl, 0, 1,  TIMESTAMP,          text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 1,  REGIME_30,          text_color=REGIME_30 == "positive_gamma" ? color.green : color.red, text_size=size.small)
    table.cell(tbl, 2, 1,  REGIME_90,          text_color=REGIME_90 == "positive_gamma" ? color.green : color.red, text_size=size.small)

    table.cell(tbl, 0, 2,  "Underlying",       text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 2,  str.tostring(UNDERLYING), text_color=color.white, text_size=size.small)
    table.cell(tbl, 2, 2,  "",                 text_color=color.white,  text_size=size.small)

    table.cell(tbl, 0, 3,  "Gamma Flip",       text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 3,  str.tostring(GAMMA_FLIP_30), text_color=color.orange, text_size=size.small)
    table.cell(tbl, 2, 3,  str.tostring(GAMMA_FLIP_90), text_color=color.orange, text_size=size.small)

    table.cell(tbl, 0, 4,  "Call Wall",        text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 4,  str.tostring(CALL_WALL_30), text_color=color.green, text_size=size.small)
    table.cell(tbl, 2, 4,  str.tostring(CALL_WALL_90), text_color=color.green, text_size=size.small)

    table.cell(tbl, 0, 5,  "Put Wall",         text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 5,  str.tostring(PUT_WALL_30), text_color=color.red, text_size=size.small)
    table.cell(tbl, 2, 5,  str.tostring(PUT_WALL_90), text_color=color.red, text_size=size.small)

    table.cell(tbl, 0, 6,  "HVL",              text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 6,  str.tostring(HVL_30), text_color=color.aqua, text_size=size.small)
    table.cell(tbl, 2, 6,  str.tostring(HVL_90), text_color=color.aqua, text_size=size.small)

    table.cell(tbl, 0, 7,  "Net GEX",          text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 7,  NET_GEX_30,         text_color=color.white,  text_size=size.small)
    table.cell(tbl, 2, 7,  NET_GEX_90,         text_color=color.white,  text_size=size.small)

    table.cell(tbl, 0, 8,  "Net DEX",          text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 8,  str.tostring(math.round(NET_DEX_30 / 1000)) + "K", text_color=NET_DEX_30 >= 0 ? color.green : color.red, text_size=size.small)
    table.cell(tbl, 2, 8,  str.tostring(math.round(NET_DEX_90 / 1000)) + "K", text_color=NET_DEX_90 >= 0 ? color.green : color.red, text_size=size.small)

    table.cell(tbl, 0, 9,  "DEX Regime",       text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 9,  DEX_REGIME_30,      text_color=DEX_REGIME_30 == "dealer_long" ? color.green : color.red, text_size=size.small)
    table.cell(tbl, 2, 9,  DEX_REGIME_90,      text_color=DEX_REGIME_90 == "dealer_long" ? color.green : color.red, text_size=size.small)

    table.cell(tbl, 0, 10, "CPR Raw",          text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 10, str.tostring(CPR_RAW_30), text_color=CPR_RAW_30 > 1.0 ? color.green : color.red, text_size=size.small)
    table.cell(tbl, 2, 10, str.tostring(CPR_RAW_90), text_color=CPR_RAW_90 > 1.0 ? color.green : color.red, text_size=size.small)

    table.cell(tbl, 0, 11, "CPR Notional",     text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 11, str.tostring(CPR_NOTL_30), text_color=CPR_NOTL_30 > 1.0 ? color.green : color.red, text_size=size.small)
    table.cell(tbl, 2, 11, str.tostring(CPR_NOTL_90), text_color=CPR_NOTL_90 > 1.0 ? color.green : color.red, text_size=size.small)
