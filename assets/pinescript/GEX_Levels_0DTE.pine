//@version=5
indicator("GEX Levels 0DTE", overlay=true, max_lines_count=40, max_labels_count=40, max_boxes_count=10)

// ═══════════════════════════════════════════════════════════════
//  PASTE UPDATED DATA HERE EACH SESSION
//  Generated by generate_gex_0dte.py — refresh every 5 min
// ═══════════════════════════════════════════════════════════════
var string SYM        = "SPX"
var string TIMESTAMP  = "2026-06-03"
var string REGIME     = "positive_gamma"

var float UNDERLYING  = 7583.75
var float GAMMA_FLIP  = 7573.74
var float VOL_TRIGGER = 7587.76
var float HVL         = 7577.74

var float CALL_WALL   = 7607.80
var float CW_LOW      = 7587.76
var float CW_HIGH     = 7607.80

var float PUT_WALL    = 7567.72
var float PW_LOW      = 7567.72
var float PW_HIGH     = 7577.74

var float KEY_CALL_2  = 7597.78
var float KEY_CALL_3  = 7607.80
var float KEY_PUT_2   = 7567.72
var float KEY_PUT_3   = 7557.69

var string NET_GEX    = "+42.73B"
var float  NET_DEX    = -35846644.0
var string DEX_REGIME = "dealer_short"
var float  CPR_RAW    = 1.1695
var float  CPR_NOTL   = 1.1779

var float GEX_NODE1_P = 7588.0
var float GEX_NODE1_V =  24992024687.0
var float GEX_NODE2_P = 7598.0
var float GEX_NODE2_V =  24684607756.0
var float GEX_NODE3_P = 7568.0
var float GEX_NODE3_V = -13157754043.0
var float GEX_NODE4_P = 7558.0
var float GEX_NODE4_V = -9787113483.0
var float GEX_NODE5_P = 7548.0
var float GEX_NODE5_V = -3117427491.0
// ═══════════════════════════════════════════════════════════════

// ── Settings ─────────────────────────────────────────────────────
show_zones    = input.bool(true,  "Show Call/Put Wall Zones")
show_key      = input.bool(true,  "Show Key Call/Put Levels")
show_nodes    = input.bool(true,  "Show Top GEX Profile Nodes")
show_underlyi = input.bool(true,  "Show Underlying Reference Line")
show_table    = input.bool(true,  "Show Info Table")
lw            = input.int(2, "Line Width", minval=1, maxval=4)

// ── Colors — slightly different palette from daily to distinguish visually ───
// 0DTE uses brighter/more saturated versions so both indicators can coexist
C_CALL   = color.new(color.lime,    10)   // brighter green vs daily
C_PUT    = color.new(color.red,      0)   // full red vs daily's 10% transparency
C_FLIP   = color.new(color.orange,   0)
C_VT     = color.new(color.yellow,   0)
C_HVL    = color.new(color.aqua,     0)
C_KEY_C  = color.new(color.green,   20)
C_KEY_P  = color.new(color.fuchsia, 10)  // fuchsia vs daily's maroon
C_UND    = color.new(color.white,   50)
C_NODE_C = color.new(color.teal,    10)
C_NODE_P = color.new(color.purple,  10)  // purple vs daily's fuchsia

// ── Draw functions ────────────────────────────────────────────────
f_line(price, col, sty) =>
    line.new(bar_index - 100, price, bar_index, price, color=col, width=lw, style=sty, extend=extend.right)

f_label(price, txt, col, x_off) =>
    label.new(bar_index + x_off, price, txt, color=color.new(col, 88), textcolor=col, style=label.style_label_lower_left, size=size.small)

// Each label has a unique x offset so they never overlap regardless of price
if barstate.islast

    if show_underlyi
        f_line(UNDERLYING, C_UND, line.style_dotted)
        f_label(UNDERLYING, "Underlying  " + str.tostring(UNDERLYING), C_UND, 2)

    f_line(CALL_WALL,  C_CALL, line.style_solid)
    f_label(CALL_WALL,  "0D Call Wall  " + str.tostring(CALL_WALL),  C_CALL, 12)

    f_line(PUT_WALL,   C_PUT,  line.style_solid)
    f_label(PUT_WALL,   "0D Put Wall  "  + str.tostring(PUT_WALL),   C_PUT,  22)

    f_line(GAMMA_FLIP, C_FLIP, line.style_solid)
    f_label(GAMMA_FLIP, "0D Gamma Flip  " + str.tostring(GAMMA_FLIP), C_FLIP, 32)

    if VOL_TRIGGER != GAMMA_FLIP
        f_line(VOL_TRIGGER, C_VT, line.style_solid)
        f_label(VOL_TRIGGER, "0D Vol Trigger  " + str.tostring(VOL_TRIGGER), C_VT, 42)

    f_line(HVL, C_HVL, line.style_dashed)
    f_label(HVL, "0D HVL  " + str.tostring(HVL), C_HVL, 52)

    if show_key
        f_line(KEY_CALL_2,  C_KEY_C, line.style_dashed)
        f_label(KEY_CALL_2, "0D Key Call 2  " + str.tostring(KEY_CALL_2), C_KEY_C, 62)

        f_line(KEY_CALL_3,  C_KEY_C, line.style_dotted)
        f_label(KEY_CALL_3, "0D Key Call 3  " + str.tostring(KEY_CALL_3), C_KEY_C, 72)

        f_line(KEY_PUT_2,   C_KEY_P, line.style_dashed)
        f_label(KEY_PUT_2,  "0D Key Put 2  "  + str.tostring(KEY_PUT_2),  C_KEY_P, 82)

        f_line(KEY_PUT_3,   C_KEY_P, line.style_dotted)
        f_label(KEY_PUT_3,  "0D Key Put 3  "  + str.tostring(KEY_PUT_3),  C_KEY_P, 92)

    if show_zones
        if CW_HIGH != CW_LOW
            box.new(bar_index - 100, CW_HIGH, bar_index, CW_LOW, border_color=color.new(C_CALL, 40), bgcolor=color.new(C_CALL, 90), extend=extend.right)
        if PW_HIGH != PW_LOW
            box.new(bar_index - 100, PW_HIGH, bar_index, PW_LOW, border_color=color.new(C_PUT, 40),  bgcolor=color.new(C_PUT, 90),  extend=extend.right)

    if show_nodes
        if not na(GEX_NODE1_P)
            node1_col = GEX_NODE1_V >= 0 ? C_NODE_C : C_NODE_P
            f_line(GEX_NODE1_P,  node1_col, line.style_dashed)
            f_label(GEX_NODE1_P, "0D Node 1  " + str.tostring(GEX_NODE1_P), node1_col, 102)
        if not na(GEX_NODE2_P)
            node2_col = GEX_NODE2_V >= 0 ? C_NODE_C : C_NODE_P
            f_line(GEX_NODE2_P,  node2_col, line.style_dashed)
            f_label(GEX_NODE2_P, "0D Node 2  " + str.tostring(GEX_NODE2_P), node2_col, 112)
        if not na(GEX_NODE3_P)
            node3_col = GEX_NODE3_V >= 0 ? C_NODE_C : C_NODE_P
            f_line(GEX_NODE3_P,  node3_col, line.style_dashed)
            f_label(GEX_NODE3_P, "0D Node 3  " + str.tostring(GEX_NODE3_P), node3_col, 122)
        if not na(GEX_NODE4_P)
            node4_col = GEX_NODE4_V >= 0 ? C_NODE_C : C_NODE_P
            f_line(GEX_NODE4_P,  node4_col, line.style_dashed)
            f_label(GEX_NODE4_P, "0D Node 4  " + str.tostring(GEX_NODE4_P), node4_col, 132)
        if not na(GEX_NODE5_P)
            node5_col = GEX_NODE5_V >= 0 ? C_NODE_C : C_NODE_P
            f_line(GEX_NODE5_P,  node5_col, line.style_dashed)
            f_label(GEX_NODE5_P, "0D Node 5  " + str.tostring(GEX_NODE5_P), node5_col, 142)

// ── Info Table ────────────────────────────────────────────────────
var table tbl = table.new(position.top_left, 2, 13, border_width=1, border_color=color.new(color.gray, 60), bgcolor=color.new(color.black, 75))

if barstate.islast and show_table
    regime_col = REGIME     == "positive_gamma" ? color.green : color.red
    dex_col    = DEX_REGIME == "dealer_long"    ? color.green : color.red
    cpr_col    = CPR_RAW > 1.0 ? color.green : color.red

    table.cell(tbl, 0, 0,  "0DTE · " + SYM,  text_color=color.white,  text_size=size.normal, bgcolor=color.new(color.purple, 50))
    table.cell(tbl, 1, 0,  TIMESTAMP,          text_color=color.silver, text_size=size.small,  bgcolor=color.new(color.purple, 50))

    table.cell(tbl, 0, 1,  "Underlying",       text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 1,  str.tostring(UNDERLYING), text_color=color.white, text_size=size.small)

    table.cell(tbl, 0, 2,  "Regime",           text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 2,  REGIME,             text_color=regime_col,   text_size=size.small)

    table.cell(tbl, 0, 3,  "Net GEX",          text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 3,  NET_GEX,            text_color=color.white,  text_size=size.small)

    table.cell(tbl, 0, 4,  "Net DEX",          text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 4,  str.tostring(math.round(NET_DEX / 1000)) + "K", text_color=NET_DEX >= 0 ? color.green : color.red, text_size=size.small)

    table.cell(tbl, 0, 5,  "DEX Regime",       text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 5,  DEX_REGIME,         text_color=dex_col,      text_size=size.small)

    table.cell(tbl, 0, 6,  "CPR Raw",          text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 6,  str.tostring(CPR_RAW),  text_color=cpr_col,  text_size=size.small)

    table.cell(tbl, 0, 7,  "CPR Notional",     text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 7,  str.tostring(CPR_NOTL), text_color=CPR_NOTL > 1.0 ? color.green : color.red, text_size=size.small)

    table.cell(tbl, 0, 8,  "Gamma Flip",       text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 8,  str.tostring(GAMMA_FLIP), text_color=color.orange, text_size=size.small)

    table.cell(tbl, 0, 9,  "Vol Trigger",      text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 9,  str.tostring(VOL_TRIGGER), text_color=color.yellow, text_size=size.small)

    table.cell(tbl, 0, 10, "Call Wall",        text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 10, str.tostring(CALL_WALL),  text_color=color.lime,   text_size=size.small)

    table.cell(tbl, 0, 11, "Put Wall",         text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 11, str.tostring(PUT_WALL),   text_color=color.red,    text_size=size.small)

    table.cell(tbl, 0, 12, "HVL",              text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 12, str.tostring(HVL),          text_color=color.aqua,   text_size=size.small)
